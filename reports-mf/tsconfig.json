{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@portal/shared-ui": [
        "../shared-ui/src"
      ],
      "@portal/shared-ui/*": [
        "../shared-ui/src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/__tests__",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}